# ─────────────────────────────────────────────
# SubSync Environment Variables
# Copy this file to .env.local and fill in your
# values from the Supabase dashboard.
# ─────────────────────────────────────────────

# Supabase (free tier - get from supabase.com)
NEXT_PUBLIC_SUPABASE_URL=your_supabase_project_url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# App URL
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Stripe (free until you charge customers - stripe.com)
STRIPE_SECRET_KEY=sk_test_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# DocuSign (add when ready - docusign.com)
# DOCUSIGN_INTEGRATION_KEY=
# DOCUSIGN_SECRET_KEY=
# DOCUSIGN_ACCOUNT_ID=

# Claude API for AI Dispute Assistant (add in Month 5)
# ANTHROPIC_API_KEY=
